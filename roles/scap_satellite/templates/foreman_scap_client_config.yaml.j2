# DO NOT EDIT THIS FILE MANUALLY
# IT IS MANAGED BY ANSIBLE
# ANY MANUAL CHANGES WILL BE LOST ON THE NEXT ANSIBLE EXECUTION

# Foreman proxy to which reports should be uploaded
:server: {{ scap_satellite_server }}
:port: {{ scap_satellite_port }}

# Timeout for sending reports to proxy
:timeout: {{ scap_satellite_timeout }}

# Ciphers used when negotiating connection with scap server
{% set comm = '' if scap_satellite_ciphers is defined else '#' %}
{{ comm }}:ciphers:{{ '' if comm else ' ' + scap_satellite_ciphers | to_json }}

# Should --fetch-remote-resources be added to `oscap xccdf eval` command
:fetch_remote_resources: {{ scap_satellite_fetch_remote_resources | lower }}

# HTTP proxy server for downloading remote resources
:http_proxy_server:{{ ' ' + scap_satellite_http_proxy_server if scap_satellite_http_proxy_server is defined else '' }}
:http_proxy_port:{{ ' ' + scap_satellite_http_proxy_port if scap_satellite_http_proxy_port is defined else '' }}

## SSL specific options ##
# Client CA file.
# It could be any valid certificate that is accepted by foreman-proxy, such as Puppet CA certificate (e.g., '/var/lib/puppet/ssl/certs/ca.pem')
# Or (recommended for client reporting to Katello) subscription manager CA file, (e.g., '/etc/rhsm/ca/katello-server-ca.pem')
:ca_file: {{ scap_satellite_ca_file | default('/etc/rhsm/ca/katello-server-ca.pem') }}
# Client host certificate.
# It could be Puppet agent host certificate (e.g., '/var/lib/puppet/ssl/certs/myhost.example.com.pem')
# Or (recommended for client reporting to Katello) consumer certificate (e.g., '/etc/pki/consumer/cert.pem')
:host_certificate: {{ scap_satellite_host_certificate | default('/etc/pki/consumer/cert.pem') }}
# Client private key
# It could be Puppet agent private key (e.g., '/var/lib/puppet/ssl/private_keys/myhost.example.com.pem')
# Or (recommended for client reporting to Katello) consumer private key (e.g., '/etc/pki/consumer/key.pem')
:host_private_key: {{ scap_satellite_host_private_key | default('/etc/pki/consumer/key.pem') }}

# policy (key is id as in Foreman)
{% for policy in scap_satellite_policies %}
{{ policy['id'] }}:
  :profile: {{ policy['profile'] }}
  :content_path: /var/lib/openscap/content/{{ policy['profile'] }}.xml
  # Download path
  # A path to download SCAP content from proxy
  :download_path: /compliance/policies/{{ policy['id'] }}/content/{{ policy['profile'] }}.xml
{% if policy['tailoring_id'] is defined %}
  :tailoring_path: /var/lib/openscap/tailoring/{{ policy['tailoring_profile'] }}.xml
  :tailoring_download_path: /compliance/policies/{{ policy['tailoring_id'] }}/tailoring/{{ policy['tailoring_profile'] }}.xml
{% else %}
  :tailoring_path:
  :tailoring_download_path:
{% endif %}
{% endfor %}
